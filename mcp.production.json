{
  "mcpServers": {
    "zendesk": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@sshadows/zendesk-mcp-server"],
      "env": {
        "ZENDESK_SUBDOMAIN": "${ZENDESK_SUBDOMAIN}",
        "ZENDESK_EMAIL": "${ZENDESK_EMAIL}",
        "ZENDESK_API_TOKEN": "${ZENDESK_API_TOKEN}"
      }
    },
    "shopify": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "shopify-mcp"],
      "env": {
        "SHOPIFY_ACCESS_TOKEN": "${SHOPIFY_ACCESS_TOKEN}",
        "MYSHOPIFY_DOMAIN": "flagwix.myshopify.com"
      }
    }
  }
}
